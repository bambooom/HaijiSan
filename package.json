{
  "name": "haijisan",
  "private": true,
  "scripts": {
    "clasp:prepare": "node ./scripts/write-clasp-config.mjs",
    "build": "node ./scripts/build.mjs",
    "clean": "node ./scripts/clean.mjs",
    "lint": "eslint . --max-warnings=0",
    "sheet:validate-headers": "node ./scripts/validate-sheet-headers.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "push": "pnpm clasp:prepare && pnpm build && pnpm exec clasp push --force",
    "deploy": "pnpm clasp:prepare && pnpm build && node ./scripts/deploy.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@google/clasp": "^3.0.6",
    "@types/google-apps-script": "^2.0.8",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "dotenv": "^16.5.0",
    "esbuild": "^0.25.2",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
