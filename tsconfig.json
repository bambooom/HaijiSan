{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["google-apps-script"]
  },
  "include": ["src/**/*.ts", "eslint.config.mjs", "scripts/**/*.mjs"],
  "exclude": ["dist", "node_modules"]
}
